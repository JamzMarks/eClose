# =============================================================================
# eClose API — variáveis de ambiente (exemplo)
# Raiz: apps/api
# =============================================================================
#
# Ambientes (APP_ENV): development | uat | production
# ───────────────────────────────────────────────────
# O loader (`loadAppEnv`) aplica por ordem:
#   1) .env
#   2) .env.{APP_ENV}   → ficheiros commitados: .env.development, .env.uat
#   3) .env.local       → overrides locais (gitignored); não definir APP_ENV aqui se confundir com scripts
#
# Comandos (na pasta apps/api ou via pnpm --filter api <script>):
#   DEV:   pnpm infra:up:dev   &&  pnpm dev
#   UAT:   pnpm infra:up:uat  &&  pnpm dev:uat     (Postgres 5433, Redis 6380)
#   PROD:  definir segredos no host/CI; ver .env.production.example;  pnpm build && pnpm start:prod
#
# Migrações: pnpm migration:run  |  pnpm migration:run:uat
#
# =============================================================================

APP_ENV=development
NODE_ENV=development

# --- Servidor HTTP ---
PORT=3000

# --- PostgreSQL (relacional, TypeORM) — obrigatório ---
# Com Docker Compose (docker.compose.yaml), credenciais por defeito batem com o compose.
DATABASE_URL=postgresql://eclose:eclose_dev@localhost:5432/eclose

# Campos explícitos (opcional; úteis para scripts, Compose ou ferramentas que não usam URL)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eclose
POSTGRES_PASSWORD=eclose_dev
POSTGRES_DB=eclose

# --- Redis (NoSQL em memória — recomendado para esta stack) ---
# Uso típico: cache de leitura, rate limiting, locks, filas leves.
# A API ainda pode não ler REDIS_URL; subir o serviço prepara ambiente para integração futura.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Porquê Redis e não MongoDB aqui?
# - O núcleo já está em Postgres + jsonb (flexível sem segundo document store).
# - Redis cobre padrões de “não relacional” que mais interessam ao produto: velocidade, TTL, contadores.
# - MongoDB faria sentido se precisasses de coleções grandes com schema muito volátil e consultas fora do SQL.

# Opcional: aplicar migrações TypeORM ao subir
TYPEORM_RUN_MIGRATIONS=false

# Apenas desenvolvimento sem migrações (não usar em produção)
TYPEORM_SYNC=false

# Logs SQL (TypeORM)
TYPEORM_LOGGING=false

JWT_SECRET=change-me
JWT_ACCESS_EXPIRES=15m

# OAuth HTTP (Google; Apple/Meta em roadmap)
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# Adapter de mídia: omitir ou "local"; "http" chama MEDIA_SERVICE_URL
MEDIA_ADAPTER=local
MEDIA_SERVICE_URL=
MEDIA_SERVICE_INTERNAL_TOKEN=

# Upload assinado + CDN público
MEDIA_UPLOAD_BASE_URL=
MEDIA_CDN_PUBLIC_BASE_URL=

# Pipeline assíncrono de mídia (outbox in-process)
MEDIA_ASYNC_PIPELINE=false
MEDIA_THUMB_URL_SUFFIX=

# Lista MIME imagens (vírgula); vazio = padrão jpeg/png/webp/gif
MEDIA_ALLOWED_IMAGE_MIMES=
